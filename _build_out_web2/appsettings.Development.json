{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=Evolver.dev.db"
  },
  "Jwt": {
    "Issuer": "Evolver",
    "Audience": "Evolver",
    "SigningKey": "dev-only-change-me-please-32bytes-minimum-abcdef",
    "ExpMinutes": 720
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "shared": true
        }
      }
    ]
  }
}

@inherits LayoutComponentBase
@using Evolver.Frontend.Services
@inject AuthTokenStore Tokens
@inject IJSRuntime Js
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <span class="text-muted small">Grill Shack / Evolver</span>
            <div>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LogoutAsync">退出登录</button>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task LogoutAsync()
    {
        Tokens.Clear();
        await Tokens.ClearBrowserAsync(Js);
        Nav.NavigateTo("/login", forceLoad: false, replace: true);
    }
}

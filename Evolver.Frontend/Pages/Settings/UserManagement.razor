    private static string ReadErrorText(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "请求失败。";
        try
        {
            var env = JsonSerializer.Deserialize<ApiEnvelopeJson<JsonElement>>(text, JsonOpts);
            if (!string.IsNullOrEmpty(env?.Message))
                return env.Message!;
        }
        catch
        {
            // plain text
        }

        return text.Length > 400 ? text[..400] + "…" : text;
    }

    private static void ToggleSet(HashSet<string> set, string value, ChangeEventArgs e)
    {
        var on = e.Value is bool b && b;
        if (on) set.Add(value);
        else set.Remove(value);
    }

    private static void ToggleSet(HashSet<long> set, long value, ChangeEventArgs e)
    {
        var on = e.Value is bool b && b;
        if (on) set.Add(value);
        else set.Remove(value);
    }

    private static IEnumerable<(OrganizationTreeNodeDto node, int depth)> FlattenOrgTree(IEnumerable<OrganizationTreeNodeDto> roots)
    {
        foreach (var r in roots)
        {
            foreach (var x in Walk(r, 0))
                yield return x;
        }
    }

    private static IEnumerable<(OrganizationTreeNodeDto node, int depth)> Walk(OrganizationTreeNodeDto n, int depth)
    {
        yield return (n, depth);
        foreach (var c in n.Children)
        {
            foreach (var x in Walk(c, depth + 1))
                yield return x;
        }
    }

@page "/settings/users"
@using System.Text.Json.Serialization
@using Evolver.Frontend.Components.DataTable
@using System.Text.Json
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject HttpClient Http
@inject AuthTokenStore Tokens
@inject IJSRuntime JS

<PageTitle>用户管理</PageTitle>

<h1 class="mb-2">用户管理</h1>
<p class="text-muted mb-3">维护可登录系统的账号（用户名、联系方式）、启用状态、角色与组织归属；支持列表检索、批量导入导出，以及由具备权限的管理员修改或重置密码。</p>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

@if (_success is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @_success
        <button type="button" class="btn-close" @onclick="() => _success = null"></button>
    </div>
}

@if (_pane == UserPane.List)
{
    <div class="row g-3">
        <div class="col-12 col-lg-2">
            <div class="card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>组织树</span>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearOrgFilterAsync" disabled="@_busy">全部</button>
                </div>
                <div class="card-body p-2" style="max-height:calc(100vh - 260px);overflow:auto">
                    @if (_orgRoots.Count == 0)
                    {
                        <div class="text-muted small px-2">暂无组织</div>
                    }
                    else
                    {
                        @foreach (var (node, depth) in FlattenOrgTree(_orgRoots))
                        {
                            <button type="button"
                                    class="btn btn-sm w-100 text-start mb-1 ev-user-org-tree-btn @(_selectedOrgId == node.Id ? "ev-user-org-tree-btn--active" : "")"
                                    style="padding-left:@($"{0.75 + depth * 1.1}rem")"
                                    @ondragover="OnOrgNodeDragOver"
                                    @ondrop="async _ => await OnOrgNodeDropAsync(node.Id)"
                                    @onclick="() => SelectOrgNodeAsync(node.Id)">
                                @node.Name
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-10">
            <EvolverDataTable TableHostId="@UserTableHostId" Loading="@(_users is null)">
                <ToolbarStart>
                    <div class="position-relative">
                        <span class="ev-toolbar-search-icon position-absolute top-50 start-0 translate-middle-y ms-3 text-body-secondary"
                              aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                            </svg>
                        </span>
                        <label class="visually-hidden" for="user-global-filter">全文检索</label>
                        <input id="user-global-filter" type="search" class="form-control ps-5 ev-toolbar-search-input" placeholder="全文检索"
                               value="@_globalFilter" @oninput="OnGlobalFilterInput" disabled="@_busy" autocomplete="off" />
                    </div>
                </ToolbarStart>
                <ToolbarEnd>
                    <button type="button" class="btn btn-primary btn-sm px-3" @onclick="OpenCreateAsync" disabled="@_busy">
                        <i class="bi bi-plus-lg me-1"></i>新增
                    </button>
                    <div @ref="_exportDropdownRoot" class="dropdown position-relative">
                        <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle"
                                @onclick="OpenExportMenu"
                                disabled="@(_busy || _users is null)">
                            <i class="bi bi-download me-1"></i>导出
                        </button>
                        @if (_exportMenuOpen)
                        {
                            <div class="dropdown-menu show position-absolute end-0 mt-1 shadow py-1" style="z-index:40;min-width:10rem">
                                <button type="button" class="dropdown-item" @onclick='@(() => ExportAndCloseAsync("csv"))'>CSV</button>
                                <button type="button" class="dropdown-item" @onclick='@(() => ExportAndCloseAsync("xlsx"))'>Excel</button>
                                <button type="button" class="dropdown-item" @onclick='@(() => ExportAndCloseAsync("pdf"))'>PDF</button>
                            </div>
                        }
                    </div>
                    <label class="btn btn-outline-secondary btn-sm mb-0" title="服务端导入 .xlsx，工作表名 Users">
                        <i class="bi bi-upload me-1"></i>导入
                        <InputFile OnChange="ImportExcelAsync" accept=".xlsx" class="d-none" />
                    </label>
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ReloadAllAsync" disabled="@_busy">
                        <i class="bi bi-arrow-clockwise me-1"></i>刷新
                    </button>
                    <div @ref="_columnDropdownRoot" class="dropdown position-relative">
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                title="显示列"
                                @onclick="ToggleColumnMenuAsync"
                                disabled="@(_busy || _users is null)">
                            <i class="bi bi-layout-three-columns"></i>
                        </button>
                        @if (_columnMenuOpen)
                        {
                            <div class="dropdown-menu show position-absolute end-0 mt-1 shadow py-2 ev-colvis-menu" style="z-index:40">
                                <div class="dropdown-header ev-colvis-menu-header">
                                    <label class="form-check mb-0">
                                        <input class="form-check-input" type="checkbox" checked="@_allColumnsVisible" @onchange="OnToggleAllColumnsAsync" />
                                        <span class="form-check-label">列展示</span>
                                    </label>
                                </div>
                                <div class="dropdown-divider"></div>
                                @foreach (var col in _columnItems)
                                {
                                    <label class="dropdown-item ev-colvis-item">
                                        <input class="form-check-input" type="checkbox" checked="@col.Visible"
                                               @onchange="e => OnColumnVisibilityChangedAsync(col.Field, e)" />
                                        @col.Title
                                    </label>
                                }
                            </div>
                        }
                    </div>
                </ToolbarEnd>
            </EvolverDataTable>
        </div>
    </div>
}
else if (_pane == UserPane.Create)
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">返回用户列表</button>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">新建用户</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label">用户名 <span class="text-danger">*</span></label>
                    <input class="form-control @(string.IsNullOrEmpty(DisplayCreateUserNameError()) ? "" : "is-invalid")"
                           @bind="_cUserName" @bind:event="oninput" autocomplete="off" />
                    @if (DisplayCreateUserNameError() is { } uErr)
                    {
                        <div class="invalid-feedback d-block">@uErr</div>
                    }
                </div>
                <div class="col-md-6">
                    <label class="form-label">初始密码 <span class="text-danger">*</span></label>
                    <input class="form-control @(string.IsNullOrEmpty(DisplayCreatePasswordError()) ? "" : "is-invalid")"
                           type="password" @bind="_cPassword" @bind:event="oninput" autocomplete="new-password" />
                    @if (DisplayCreatePasswordError() is { } pErr)
                    {
                        <div class="invalid-feedback d-block">@pErr</div>
                    }
                    else if (!string.IsNullOrEmpty(_cPassword))
                    {
                        <small class="text-muted">@GetPasswordStrengthHint(_cPassword)</small>
                    }
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input class="form-control @(string.IsNullOrEmpty(DisplayCreateEmailError()) ? "" : "is-invalid")"
                           type="email" @bind="_cEmail" @bind:event="oninput" />
                    @if (DisplayCreateEmailError() is { } eErr)
                    {
                        <div class="invalid-feedback d-block">@eErr</div>
                    }
                </div>
                <div class="col-md-6">
                    <label class="form-label">电话</label>
                    <input class="form-control @(string.IsNullOrEmpty(DisplayCreatePhoneError()) ? "" : "is-invalid")"
                           @bind="_cPhone" @bind:event="oninput" />
                    @if (DisplayCreatePhoneError() is { } phErr)
                    {
                        <div class="invalid-feedback d-block">@phErr</div>
                    }
                </div>
                <div class="col-12">
                    <label class="form-label">备注</label>
                    <textarea class="form-control" rows="2" @bind="_cRemark" @bind:event="oninput"></textarea>
                </div>
                <div class="col-12">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="createActive" @bind="_cIsActive" />
                        <label class="form-check-label" for="createActive">账户启用（正常）；关闭则为停用，不可登录</label>
                    </div>
                </div>
            </div>
            @if (_roleOptions.Count > 0)
            {
                <div class="mt-3">
                    <label class="form-label">角色</label>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var r in _roleOptions)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="@($"cr-{r.Id}")"
                                       checked="@_cRoles.Contains(r.Name)"
                                       @onchange="e => ToggleSet(_cRoles, r.Name, e)" />
                                <label class="form-check-label" for="@($"cr-{r.Id}")">@r.Name</label>
                            </div>
                        }
                    </div>
                </div>
            }
            @if (_orgRoots is { Count: > 0 })
            {
                <div class="mt-3">
                    <label class="form-label">归属部门</label>
                    <select class="form-select" @bind="_cDepartmentIdStr">
                        <option value="">请选择归属部门</option>
                        @foreach (var (node, depth) in FlattenOrgTree(_orgRoots))
                        {
                            <option value="@node.Id">@($"{new string('　', depth)}{node.Name}")</option>
                        }
                    </select>
                </div>
            }
            <div class="mt-4 d-flex gap-2">
                <button type="button" class="btn btn-primary" @onclick="CreateUserAsync" disabled="@(_busy || !IsCreateFormValid())">保存</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">取消</button>
            </div>
        </div>
    </div>
}
else if (_pane == UserPane.Edit)
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync"
                disabled="@(_busy && _editDetail is not null)">返回用户列表</button>
    </div>

    @if (_editDetail is null)
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
                <p class="mt-3 mb-0 text-muted">正在加载用户资料…</p>
            </div>
        </div>
    }
    else
    {
    <div class="card shadow-sm">
        <div class="card-header">编辑用户 — @_editDetail.UserName</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label">用户名</label>
                    <input class="form-control" value="@_editDetail.UserName" disabled />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input class="form-control @(string.IsNullOrEmpty(DisplayEditEmailError()) ? "" : "is-invalid")"
                           type="email" @bind="_eEmail" @bind:event="oninput" />
                    @if (DisplayEditEmailError() is { } eeErr)
                    {
                        <div class="invalid-feedback d-block">@eeErr</div>
                    }
                </div>
                <div class="col-md-6">
                    <label class="form-label">电话</label>
                    <input class="form-control @(string.IsNullOrEmpty(DisplayEditPhoneError()) ? "" : "is-invalid")"
                           @bind="_ePhone" @bind:event="oninput" />
                    @if (DisplayEditPhoneError() is { } epErr)
                    {
                        <div class="invalid-feedback d-block">@epErr</div>
                    }
                </div>
                <div class="col-12">
                    <label class="form-label">备注</label>
                    <textarea class="form-control" rows="2" @bind="_eRemark" @bind:event="oninput"></textarea>
                </div>
                <div class="col-12">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="editActive" @bind="_eIsActive" />
                        <label class="form-check-label" for="editActive">账户启用（正常）；关闭则为停用，不可登录</label>
                    </div>
                </div>
            </div>
            @if (_roleOptions.Count > 0)
            {
                <div class="mt-3">
                    <label class="form-label">角色</label>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var r in _roleOptions)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="@($"er-{r.Id}")"
                                       checked="@_eRoles.Contains(r.Name)"
                                       @onchange="e => ToggleSet(_eRoles, r.Name, e)" />
                                <label class="form-check-label" for="@($"er-{r.Id}")">@r.Name</label>
                            </div>
                        }
                    </div>
                </div>
            }
            @if (_orgRoots is { Count: > 0 })
            {
                <div class="mt-3">
                    <label class="form-label">归属部门</label>
                    <select class="form-select" @bind="_eDepartmentIdStr">
                        <option value="">请选择归属部门</option>
                        @foreach (var (node, depth) in FlattenOrgTree(_orgRoots))
                        {
                            <option value="@node.Id">@($"{new string('　', depth)}{node.Name}")</option>
                        }
                    </select>
                </div>
            }
            <div class="mt-4 d-flex gap-2">
                <button type="button" class="btn btn-primary" @onclick="SaveEditAsync" disabled="@(_busy || !IsEditFormValid())">保存</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">取消</button>
            </div>
        </div>
    </div>
    }
}
else if (_pane == UserPane.ResetPassword && _passwordUserId is not null)
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">返回用户列表</button>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">重置密码 — @_passwordUserLabel</div>
        <div class="card-body">
            <label class="form-label">新密码 <span class="text-danger">*</span></label>
            <input class="form-control @(string.IsNullOrEmpty(DisplayPasswordResetError()) ? "" : "is-invalid")"
                   type="password" @bind="_newPassword" @bind:event="oninput" autocomplete="new-password" />
            @if (DisplayPasswordResetError() is { } npErr)
            {
                <div class="invalid-feedback d-block">@npErr</div>
            }
            else if (!string.IsNullOrEmpty(_newPassword))
            {
                <small class="text-muted">@GetPasswordStrengthHint(_newPassword)</small>
            }
            <div class="mt-4 d-flex gap-2">
                <button type="button" class="btn btn-primary" @onclick="SavePasswordAsync" disabled="@(_busy || !IsNewPasswordValid())">保存</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">取消</button>
            </div>
        </div>
    </div>
}
else if (_pane == UserPane.DeleteConfirm && _deleteId is not null)
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">返回用户列表</button>
    </div>

    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">确认删除</div>
        <div class="card-body">
            <p class="mb-3">确定删除用户 Id <strong>@_deleteId</strong>？此操作为软删除。</p>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-danger" @onclick="DeleteConfirmedAsync" disabled="@_busy">删除</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">取消</button>
            </div>
        </div>
    </div>
}

@code {
    private enum UserPane { List, Create, Edit, ResetPassword, DeleteConfirm }

    private const string UserTableHostId = "evolver-user-tabulator-host";

    private static readonly JsonSerializerOptions JsonOpts = new() { PropertyNameCaseInsensitive = true };

    private static readonly JsonSerializerOptions TabulatorJsonOpts = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    private static readonly Regex EmailRegex = new(
        @"^[^@\s]+@[^@\s]+\.[^@\s]+$",
        RegexOptions.Compiled | RegexOptions.CultureInvariant);

    private const int PasswordMinLength = 6;

    private string? _error;
    private string? _success;
    private bool _busy;
    private long? _currentUserId;

    private UserPane _pane = UserPane.List;

    private List<UserListItemDto>? _users;
    private List<RoleDto> _roleOptions = new();
    private List<OrganizationTreeNodeDto> _orgRoots = new();

    private string _cUserName = "";
    private string _cPassword = "";
    private string? _cEmail;
    private string? _cPhone;
    private string? _cRemark;
    private string _cDepartmentIdStr = "";
    private readonly HashSet<string> _cRoles = new(StringComparer.Ordinal);
    private bool _cIsActive = true;

    private bool _createAttempted;
    private bool _editAttempted;
    private bool _passwordAttempted;

    private long _editId;
    private UserDetailDto? _editDetail;
    private string? _eEmail;
    private string? _ePhone;
    private string? _eRemark;
    private string _eDepartmentIdStr = "";
    private readonly HashSet<string> _eRoles = new(StringComparer.Ordinal);
    private bool _eIsActive = true;

    private long? _passwordUserId;
    private string _passwordUserLabel = "";
    private string _newPassword = "";

    private long? _deleteId;

    private string _globalFilter = "";
    private long? _selectedOrgId;
    private bool _exportMenuOpen;
    private bool _exportClickOutsideRegistered;
    private ElementReference _exportDropdownRoot;
    private bool _columnMenuOpen;
    private bool _columnClickOutsideRegistered;
    private ElementReference _columnDropdownRoot;
    private List<ColumnVisibilityItem> _columnItems = new();
    private bool _allColumnsVisible = true;
    private int _dataTick;
    private int _tabulatorSyncedTick = -1;
    private DotNetObjectReference<UserManagement>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _currentUserId = JwtUserIdReader.TryGetUserId(Tokens.AccessToken);
        await ReloadAllAsync();
    }

    // 刷新：清空检索与导出菜单，销毁表格实例以恢复首次加载的默认排序/分页/筛选，再拉取接口数据重建表
    private async Task ReloadAllAsync()
    {
        _error = null;
        _success = null;
        _globalFilter = "";
        _exportMenuOpen = false;
        _columnMenuOpen = false;

        if (_exportClickOutsideRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("evolverUi.stopExportMenuClickOutside");
            }
            catch (JSDisconnectedException) { }
            _exportClickOutsideRegistered = false;
        }

        if (_columnClickOutsideRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("evolverUi.stopColumnMenuClickOutside");
            }
            catch (JSDisconnectedException) { }
            _columnClickOutsideRegistered = false;
        }

        if (_pane == UserPane.List && _tabulatorSyncedTick >= 0)
        {
            await DestroyTabulatorAsync();
            _tabulatorSyncedTick = -1;
        }

        await Task.WhenAll(LoadUsersAsync(), LoadRolesAsync(), LoadOrgTreeAsync());
        await InvokeAsync(StateHasChanged);
    }

    private async Task CancelToListAsync()
    {
        _pane = UserPane.List;
        _editDetail = null;
        _passwordUserId = null;
        _passwordUserLabel = "";
        _newPassword = "";
        _deleteId = null;
        _createAttempted = false;
        _editAttempted = false;
        _passwordAttempted = false;
        await LoadUsersAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pane != UserPane.List)
        {
            if (_tabulatorSyncedTick >= 0)
            {
                await DestroyTabulatorAsync();
                _tabulatorSyncedTick = -1;
            }
            if (_exportClickOutsideRegistered)
            {
                try
                {
                    await JS.InvokeVoidAsync("evolverUi.stopExportMenuClickOutside");
                }
                catch (JSDisconnectedException) { }
                _exportClickOutsideRegistered = false;
            }
            if (_columnClickOutsideRegistered)
            {
                try
                {
                    await JS.InvokeVoidAsync("evolverUi.stopColumnMenuClickOutside");
                }
                catch (JSDisconnectedException) { }
                _columnClickOutsideRegistered = false;
            }
            return;
        }

        if (_exportMenuOpen && !_exportClickOutsideRegistered)
        {
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync(
                    "evolverUi.startExportMenuClickOutside",
                    _exportDropdownRoot,
                    _dotNetRef,
                    nameof(OnExportMenuClickOutside));
                _exportClickOutsideRegistered = true;
            }
            catch (JSDisconnectedException) { }
        }
        else if (!_exportMenuOpen && _exportClickOutsideRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("evolverUi.stopExportMenuClickOutside");
            }
            catch (JSDisconnectedException) { }
            _exportClickOutsideRegistered = false;
        }

        if (_columnMenuOpen && !_columnClickOutsideRegistered)
        {
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync(
                    "evolverUi.startColumnMenuClickOutside",
                    _columnDropdownRoot,
                    _dotNetRef,
                    nameof(OnColumnMenuClickOutside));
                _columnClickOutsideRegistered = true;
            }
            catch (JSDisconnectedException) { }
        }
        else if (!_columnMenuOpen && _columnClickOutsideRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("evolverUi.stopColumnMenuClickOutside");
            }
            catch (JSDisconnectedException) { }
            _columnClickOutsideRegistered = false;
        }

        if (_users is null)
            return;

        if (_dataTick == _tabulatorSyncedTick)
            return;

        await SyncUserTabulatorToDomAsync();
    }

    // 将内存中的用户列表同步到 Tabulator（供 OnAfterRender 与导入完成后显式刷新）
    private async Task SyncUserTabulatorToDomAsync()
    {
        if (_users is null)
            return;
        try
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            var json = JsonSerializer.Serialize(
                _users.Select(u => new
                {
                    id = u.Id,
                    userName = u.UserName,
                    email = u.Email,
                    phoneNumber = u.PhoneNumber,
                    departmentName = u.DepartmentName ?? "",
                    rolesText = string.Join(", ", u.Roles),
                    statusText = u.IsActive ? "正常" : "停用",
                    isActive = u.IsActive,
                    updateTimeText = u.UpdateTime?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "",
                    updateByText = u.UpdateByUserName ?? (u.UpdateBy?.ToString() ?? ""),
                    remark = u.Remark ?? ""
                }).ToList(),
                TabulatorJsonOpts);
            await EvolverDataTableInterop.SyncAsync(JS, UserTableHostId, json, _dotNetRef, EvolverDataTableSchemas.Users, _currentUserId);
            _tabulatorSyncedTick = _dataTick;
            await ApplyGlobalFilterJsAsync();
            if (_columnMenuOpen)
                await LoadColumnVisibilityMenuAsync();
        }
        catch (JSDisconnectedException)
        {
            // WASM 已卸载

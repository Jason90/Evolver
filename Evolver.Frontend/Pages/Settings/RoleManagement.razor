@page "/settings/roles"
@using System.Text.Json
@using System.Text.Json.Serialization
@implements IAsyncDisposable
@inject HttpClient Http
@inject AuthTokenStore Tokens
@inject IJSRuntime JS

<PageTitle>角色管理</PageTitle>

<h1 class="mb-2">角色管理</h1>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

@if (_success is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @_success
        <button type="button" class="btn-close" @onclick="() => _success = null"></button>
    </div>
}

@if (_pane == RolePane.List)
{
    <EvolverDataTable TableHostId="@RoleTableHostId" Loading="@(_roles is null)">
        <ToolbarStart>
            <div class="position-relative">
                <span class="ev-toolbar-search-icon position-absolute top-50 start-0 translate-middle-y ms-3 text-body-secondary"
                      aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                    </svg>
                </span>
                <label class="visually-hidden" for="role-global-filter">全文检索</label>
                <input id="role-global-filter" type="search" class="form-control ps-5 ev-toolbar-search-input" placeholder="全文检索"
                       value="@_globalFilter" @oninput="OnGlobalFilterInput" disabled="@_busy" autocomplete="off" />
            </div>
        </ToolbarStart>
        <ToolbarEnd>
            <button type="button" class="btn btn-primary btn-sm px-3" @onclick="OpenCreateAsync" disabled="@_busy">
                <i class="bi bi-plus-lg me-1"></i>新增
            </button>
            <div @ref="_exportDropdownRoot" class="dropdown position-relative">
                <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle"
                        @onclick="() => _exportMenuOpen = !_exportMenuOpen"
                        disabled="@(_busy || _roles is null)">
                    <i class="bi bi-download me-1"></i>导出
                </button>
                @if (_exportMenuOpen)
                {
                    <div class="dropdown-menu show position-absolute end-0 mt-1 shadow py-1" style="z-index:40;min-width:10rem">
                        <button type="button" class="dropdown-item" @onclick='@(() => ExportAndCloseAsync("csv"))'>CSV</button>
                        <button type="button" class="dropdown-item" @onclick='@(() => ExportAndCloseAsync("xlsx"))'>Excel</button>
                        <button type="button" class="dropdown-item" @onclick='@(() => ExportAndCloseAsync("pdf"))'>PDF</button>
                    </div>
                }
            </div>
            <label class="btn btn-outline-secondary btn-sm mb-0" title="服务端导入 .xlsx，工作表名 Roles">
                <i class="bi bi-upload me-1"></i>导入
                <InputFile OnChange="ImportExcelAsync" accept=".xlsx" class="d-none" />
            </label>
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ReloadAllAsync" disabled="@_busy">
                <i class="bi bi-arrow-clockwise me-1"></i>刷新
            </button>
        </ToolbarEnd>
    </EvolverDataTable>
}
else if (_pane == RolePane.Create)
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">返回角色列表</button>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">新建角色</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label">角色名称 <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="_cName" @bind:event="oninput" placeholder="例如 Sales" disabled="@_busy" autocomplete="off" />
                </div>
                <div class="col-12">
                    <label class="form-label">所属组织</label>
                    <p class="text-muted small mb-2">不选则使用当前租户的默认组织（与列表「组织 Id」一致）。</p>
                    <div class="border rounded p-2 bg-light" style="max-height:12rem;overflow:auto">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="cRoleOrg" id="c-role-org-def"
                                   checked="@(_cOrgId is null)"
                                   @onchange="@(() => { _cOrgId = null; })" />
                            <label class="form-check-label" for="c-role-org-def">默认（租户默认组织）</label>
                        </div>
                        @foreach (var (node, depth) in FlattenOrgTree(_orgRoots))
                        {
                            if (node.Id > int.MaxValue)
                            {
                                continue;
                            }
                            var oid = (int)node.Id;
                            <div class="form-check" style="padding-left:@($"{1.25 + depth * 1.25}rem")">
                                <input class="form-check-input" type="radio" name="cRoleOrg" id="@($"c-org-{node.Id}")"
                                       checked="@(_cOrgId == oid)"
                                       @onchange="@(() => { _cOrgId = oid; })" />
                                <label class="form-check-label" for="@($"c-org-{node.Id}")">@node.Name</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="button" class="btn btn-primary" @onclick="CreateRoleAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_cName))">保存</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">取消</button>
            </div>
        </div>
    </div>
}
else if (_pane == RolePane.Edit)
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync"
                disabled="@(_busy && _editDetail is not null)">返回角色列表</button>
    </div>

    @if (_editDetail is null)
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
                <p class="mt-3 mb-0 text-muted">正在加载角色…</p>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header">编辑角色 — @_editDetail.Name</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">角色名称 <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_eName" @bind:event="oninput" disabled="@_busy" autocomplete="off" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">租户 Id</label>
                        <input class="form-control" value="@_editDetail.TenantId.ToString()" disabled />
                    </div>
                    <div class="col-12">
                        <label class="form-label">所属组织</label>
                        <div class="border rounded p-2 bg-light" style="max-height:12rem;overflow:auto">
                            @foreach (var (node, depth) in FlattenOrgTree(_orgRoots))
                            {
                                if (node.Id > int.MaxValue)
                                {
                                    continue;
                                }
                                var oid = (int)node.Id;
                                <div class="form-check" style="padding-left:@($"{1.25 + depth * 1.25}rem")">
                                    <input class="form-check-input" type="radio" name="eRoleOrg" id="@($"e-org-{node.Id}")"
                                           checked="@(_eOrgId == oid)"
                                           @onchange="@(() => { _eOrgId = oid; })" />
                                    <label class="form-check-label" for="@($"e-org-{node.Id}")">@node.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="mt-4 d-flex gap-2">
                    <button type="button" class="btn btn-primary" @onclick="SaveEditAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_eName))">保存</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">取消</button>
                </div>
            </div>
        </div>

        <RolePermissionEditor @key="_editId" RoleId="_editId" RoleName="@(_editDetail.Name)"
                              OnSaved="MarkPermSaved" OnClose="PermEditorClosedAsync" />
    }
}
else if (_pane == RolePane.DeleteConfirm && _deleteId is not null)
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">返回角色列表</button>
    </div>

    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">确认删除</div>
        <div class="card-body">
            <p class="mb-3">确定删除角色 Id <strong>@_deleteId</strong>？此操作为逻辑删除；将解除用户与该角色的关联并清空该角色的权限分配。</p>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-danger" @onclick="DeleteConfirmedAsync" disabled="@_busy">删除</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">取消</button>
            </div>
        </div>
    </div>
}

@code {
    private enum RolePane { List, Create, Edit, DeleteConfirm }

    private const string RoleTableHostId = "evolver-role-tabulator-host";

    private static readonly JsonSerializerOptions JsonOpts = new() { PropertyNameCaseInsensitive = true };

    private static readonly JsonSerializerOptions TabulatorJsonOpts = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    private string? _error;
    private string? _success;
    private bool _busy;
    private long? _currentUserId;

    private RolePane _pane = RolePane.List;

    private List<RoleDto>? _roles;
    private List<OrganizationTreeNodeDto> _orgRoots = new();

    private string _cName = "";
    private int? _cOrgId;

    private long _editId;
    private RoleDetailDto? _editDetail;
    private string _eName = "";
    private int _eOrgId;

    private long? _deleteId;

    private string _globalFilter = "";
    private bool _exportMenuOpen;
    private bool _exportClickOutsideRegistered;
    private ElementReference _exportDropdownRoot;
    private int _dataTick;
    private int _tabulatorSyncedTick = -1;
    private DotNetObjectReference<RoleManagement>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _currentUserId = JwtUserIdReader.TryGetUserId(Tokens.AccessToken);
        await ReloadAllAsync();
    }

    private async Task ReloadAllAsync()
    {
        _error = null;
        _success = null;
        _globalFilter = "";
        _exportMenuOpen = false;

        if (_exportClickOutsideRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("evolverUi.stopExportMenuClickOutside");
            }
            catch (JSDisconnectedException) { }
            _exportClickOutsideRegistered = false;
        }

        if (_pane == RolePane.List && _tabulatorSyncedTick >= 0)
        {
            await DestroyTabulatorAsync();
            _tabulatorSyncedTick = -1;
        }

        await Task.WhenAll(LoadRolesAsync(), LoadOrgTreeAsync());
        await InvokeAsync(StateHasChanged);
    }

    private async Task CancelToListAsync()
    {
        _pane = RolePane.List;
        _editDetail = null;
        _deleteId = null;
        await LoadRolesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pane != RolePane.List)
        {
            if (_tabulatorSyncedTick >= 0)
            {
                await DestroyTabulatorAsync();
                _tabulatorSyncedTick = -1;
            }
            if (_exportClickOutsideRegistered)
            {
                try
                {
                    await JS.InvokeVoidAsync("evolverUi.stopExportMenuClickOutside");
                }
                catch (JSDisconnectedException) { }
                _exportClickOutsideRegistered = false;
            }
            return;
        }

        if (_exportMenuOpen && !_exportClickOutsideRegistered)
        {
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync(
                    "evolverUi.startExportMenuClickOutside",
                    _exportDropdownRoot,
                    _dotNetRef,
                    nameof(OnExportMenuClickOutside));
                _exportClickOutsideRegistered = true;
            }
            catch (JSDisconnectedException) { }
        }
        else if (!_exportMenuOpen && _exportClickOutsideRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("evolverUi.stopExportMenuClickOutside");
            }
            catch (JSDisconnectedException) { }
            _exportClickOutsideRegistered = false;
        }

        if (_roles is null)
            return;

        if (_dataTick == _tabulatorSyncedTick)
            return;

        await SyncRoleTabulatorToDomAsync();
    }

    private async Task SyncRoleTabulatorToDomAsync()
    {
        if (_roles is null)
            return;
        try
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            var json = JsonSerializer.Serialize(
                _roles.Select(r => new
                {
                    id = r.Id,
                    name = r.Name,
                    normalizedName = r.NormalizedName ?? "",
                    tenantId = r.TenantId,
                    orgId = r.OrgId,
                    orgName = r.OrgName ?? "",
                    updateByText = r.UpdateBy?.ToString() ?? "—",
                    updateTimeText = r.UpdateTime is { } t ? t.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "—"
                }).ToList(),
                TabulatorJsonOpts);
            await EvolverDataTableInterop.SyncAsync(JS, RoleTableHostId, json, _dotNetRef, EvolverDataTableSchemas.Roles, _currentUserId);
            _tabulatorSyncedTick = _dataTick;
            await ApplyGlobalFilterJsAsync();
        }
        catch (JSDisconnectedException) { }
    }

    private async Task ApplyGlobalFilterJsAsync()
    {
        try
        {
            await EvolverDataTableInterop.SetGlobalFilterAsync(JS, RoleTableHostId, _globalFilter);
        }
        catch (JSDisconnectedException) { }
    }

    private async Task DestroyTabulatorAsync()
    {
        try
        {
            await EvolverDataTableInterop.DestroyAsync(JS, RoleTableHostId);
        }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { }
    }

    private async Task TabulatorDownloadAsync(string format)
    {
        try
        {
            await EvolverDataTableInterop.DownloadAsync(JS, RoleTableHostId, format);
        }
        catch (JSDisconnectedException) { }
    }

    private async Task ExportAndCloseAsync(string format)
    {
        _exportMenuOpen = false;
        if (_busy)
            return;
        _busy = true;
        await WaitCursorInterop.SetAsync(JS, true);
        try
        {
            await TabulatorDownloadAsync(format);
        }
        finally
        {
            _busy = false;
            await WaitCursorInterop.SetAsync(JS, false);
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnExportMenuClickOutside()
    {
        if (!_exportMenuOpen)
            return Task.CompletedTask;
        _exportMenuOpen = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task OnGlobalFilterInput(ChangeEventArgs e)
    {
        _globalFilter = e.Value?.ToString() ?? "";
        await ApplyGlobalFilterJsAsync();
    }

    [JSInvokable]
    public async Task OnRoleTableEdit(long id) => await OpenEditAsync(id);

    [JSInvokable]
    public async Task OnRoleTableDelete(long id)
    {
        OpenDeletePane(id);
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_exportClickOutsideRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("evolverUi.stopExportMenuClickOutside");
            }
            catch (JSDisconnectedException) { }
            _exportClickOutsideRegistered = false;
        }

        await DestroyTabulatorAsync();
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    private async Task LoadRolesAsync()
    {
        try
        {
            var env = await Http.GetFromJsonAsync<ApiEnvelopeJson<List<RoleDto>>>("api/roles");
            _roles = env?.Success == true ? env.Data ?? new() : new();
            if (env?.Success == false)
                _error = env.Message;
            _dataTick++;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _roles = new();
            _dataTick++;
        }
    }

    private async Task LoadOrgTreeAsync()
    {
        try
        {
            var env = await Http.GetFromJsonAsync<ApiEnvelopeJson<List<OrganizationTreeNodeDto>>>("api/organizations/tree");
            _orgRoots = env?.Success == true ? env.Data ?? new() : new();
        }
        catch
        {
            _orgRoots = new();
        }
    }

    private async Task OpenCreateAsync()
    {
        _error = null;
        _success = null;
        _cName = "";
        _cOrgId = null;
        if (_orgRoots.Count == 0)
            await LoadOrgTreeAsync();
        _pane = RolePane.Create;
    }

    private async Task CreateRoleAsync()
    {
        _busy = true;
        _error = null;
        _success = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/roles", new CreateRoleDto(_cName.Trim(), _cOrgId));
            var text = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
            {
                _error = ReadErrorText(text);
                return;
            }

            _success = "角色已创建。";
            _pane = RolePane.List;
            await LoadRolesAsync();
            await SyncRoleTabulatorToDomAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OpenEditAsync(long id)
    {
        _error = null;
        _success = null;
        _editId = id;
        _editDetail = null;
        _pane = RolePane.Edit;
        await InvokeAsync(StateHasChanged);

        _busy = true;
        try
        {
            if (_orgRoots.Count == 0)
                await LoadOrgTreeAsync();

            var env = await Http.GetFromJsonAsync<ApiEnvelopeJson<RoleDetailDto>>($"api/roles/{id}");
            if (env?.Success != true || env.Data is null)
            {
                _error = env?.Message ?? "无法加载角色详情。";
                _pane = RolePane.List;
                _editDetail = null;
                await InvokeAsync(StateHasChanged);
                return;
            }

            _editDetail = env.Data;
            _eName = env.Data.Name;
            _eOrgId = env.Data.OrgId;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _pane = RolePane.List;
            _editDetail = null;
        }
        finally
        {
            _busy = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveEditAsync()
    {
        if (_editDetail is null)
            return;
        _busy = true;
        _error = null;
        _success = null;
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Put, $"api/roles/{_editId}")
            {
                Content = JsonContent.Create(new UpdateRoleDto(_eName.Trim(), _eOrgId))
            };
            var resp = await Http.SendAsync(req);
            var text = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
            {
                _error = ReadErrorText(text);
                return;
            }

            _success = "角色已更新。";
            _pane = RolePane.List;
            _editDetail = null;
            await LoadRolesAsync();
            await SyncRoleTabulatorToDomAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void OpenDeletePane(long id)
    {
        _error = null;
        _success = null;
        _deleteId = id;
        _pane = RolePane.DeleteConfirm;
    }

    private async Task DeleteConfirmedAsync()
    {
        if (_deleteId is null)
            return;
        _busy = true;
        _error = null;
        _success = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/roles/{_deleteId.Value}");
            var text = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
            {
                _error = ReadErrorText(text);
                return;
            }

            _deleteId = null;
            _success = "角色已逻辑删除。";
            _pane = RolePane.List;
            await LoadRolesAsync();
            await SyncRoleTabulatorToDomAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ImportExcelAsync(InputFileChangeEventArgs e)
    {
        if (_busy || e.FileCount == 0)
            return;
        _busy = true;
        await WaitCursorInterop.SetAsync(JS, true);
        _error = null;
        _success = null;
        try
        {
            await using var stream = e.File.OpenReadStream(20_000_000);
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(stream);
            content.Add(fileContent, "file", e.File.Name);
            var resp = await Http.PostAsync("api/roles/import", content);
            var text = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
            {
                _error = ReadErrorText(text);
                return;
            }
            var env = JsonSerializer.Deserialize<ApiEnvelopeJson<RoleImportResultDto>>(text, JsonOpts);
            if (env?.Success == true && env.Data is { } r)
            {
                _success = $"导入完成：新建 {r.Created}，更新 {r.Updated}，跳过 {r.Skipped}。";
                if (r.Messages.Count > 0)
                    _success += " " + string.Join(" ", r.Messages.Take(5));
            }
            else
                _error = env?.Message ?? "导入失败。";
            await LoadRolesAsync();
            if (_pane == RolePane.List)
                await SyncRoleTabulatorToDomAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            await WaitCursorInterop.SetAsync(JS, false);
        }
    }

    private Task MarkPermSaved()
    {
        _success = "权限已保存。";
        return Task.CompletedTask;
    }

    private Task PermEditorClosedAsync() => Task.CompletedTask;

    private static string ReadErrorText(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "请求失败。";
        try
        {
            using var doc = JsonDocument.Parse(text);
            if (doc.RootElement.TryGetProperty("message", out var m))
                return m.GetString() ?? text;
        }
        catch
        {
            // ignore
        }

        return text;
    }

    private static IEnumerable<(OrganizationTreeNodeDto node, int depth)> FlattenOrgTree(IEnumerable<OrganizationTreeNodeDto> roots)
    {
        foreach (var root in roots)
        {
            foreach (var item in FlattenOrgTreeCore(root, 0))
                yield return item;
        }
    }

    private static IEnumerable<(OrganizationTreeNodeDto node, int depth)> FlattenOrgTreeCore(OrganizationTreeNodeDto node, int depth)
    {
        yield return (node, depth);
        foreach (var ch in node.Children)
        {
            foreach (var item in FlattenOrgTreeCore(ch, depth + 1))
                yield return item;
        }
    }
}

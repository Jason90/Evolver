@page "/forgot-password"
@attribute [AllowAnonymous]
@using Evolver.Shared.Api
@using Evolver.Shared.Dtos

<PageTitle>忘记密码</PageTitle>

<h1>忘记密码</h1>
<p class="text-muted">对应 Identity 密码重置令牌流程；生产环境请通过邮件或管理员获取令牌。</p>

<div class="row">
    <div class="col-12 col-md-6">
        <div class="mb-3">
            <label class="form-label">用户名</label>
            <input class="form-control" @bind="_userName" autocomplete="username" />
        </div>
        <button type="button" class="btn btn-primary" @onclick="SubmitAsync" disabled="@_busy">提交</button>
        <a class="btn btn-link" href="login">返回登录</a>

        @if (_message is not null)
        {
            <div class="alert alert-info mt-3 mb-0">@_message</div>
        }
        @if (_devToken is not null)
        {
            <div class="alert alert-warning mt-3">
                <div class="small text-muted mb-1">开发环境返回的重置 Token（请复制到「重置密码」页）：</div>
                <textarea class="form-control font-monospace small" rows="4" readonly>@_devToken</textarea>
                <a class="btn btn-sm btn-outline-primary mt-2" href="@ResetHref">前往重置密码</a>
            </div>
        }
    </div>
</div>

@code {
    [Inject] private HttpClient Http { get; set; } = default!;

    private string _userName = "";
    private bool _busy;
    private string? _message;
    private string? _devToken;

    private string ResetHref =>
        string.IsNullOrWhiteSpace(_userName)
            ? "/reset-password"
            : $"/reset-password?userName={Uri.EscapeDataString(_userName.Trim())}";

    private async Task SubmitAsync()
    {
        _busy = true;
        _message = null;
        _devToken = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/auth/forgot-password", new ForgotPasswordRequestDto(_userName.Trim()));
            var text = await resp.Content.ReadAsStringAsync();
            var env = System.Text.Json.JsonSerializer.Deserialize<ApiEnvelopeJson<ForgotPasswordResponseDto>>(text,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (env?.Success == true && env.Data is { } d)
            {
                _message = d.Message;
                _devToken = string.IsNullOrWhiteSpace(d.ResetToken) ? null : d.ResetToken;
            }
            else
                _message = env?.Message ?? "请求失败。";
        }
        catch (Exception ex)
        {
            _message = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}

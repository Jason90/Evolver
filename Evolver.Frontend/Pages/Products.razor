@page "/products"
@using System.Globalization
@using System.Text.Json
@using Evolver.Shared.Api
@using Evolver.Shared.Dtos
@using Microsoft.AspNetCore.Components.Forms
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>商品信息</PageTitle>

<h1 class="mb-2">商品信息</h1>
<p class="text-muted mb-3">商品管理 · 维护商品基础档案，支持检索、导入导出、停用标记与删除降级策略。</p>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

@if (_success is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @_success
        <button type="button" class="btn-close" @onclick="() => _success = null"></button>
    </div>
}

@if (_pane == ProductPane.List)
{
    <EvolverDataTable TableHostId="@ProductTableHostId" Loading="@(_rows is null)">
        <ToolbarStart>
            <div class="position-relative">
                <span class="ev-toolbar-search-icon position-absolute top-50 start-0 translate-middle-y ms-3 text-body-secondary" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                    </svg>
                </span>
                <label class="visually-hidden" for="product-global-filter">全文检索</label>
                <input id="product-global-filter" type="search" class="form-control ps-5 ev-toolbar-search-input"
                       placeholder="全文检索" value="@_globalFilter" @oninput="OnGlobalFilterInput" disabled="@_busy" autocomplete="off" />
            </div>
        </ToolbarStart>
        <ToolbarEnd>
            <button type="button" class="btn btn-primary btn-sm px-3" @onclick="OpenCreate" disabled="@_busy">
                <i class="bi bi-plus-lg me-1"></i>新增
            </button>
            <div @ref="_exportDropdownRoot" class="dropdown position-relative">
                <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle"
                        @onclick="() => _exportMenuOpen = !_exportMenuOpen"
                        disabled="@(_busy || _rows is null)">
                    <i class="bi bi-download me-1"></i>导出
                </button>
                @if (_exportMenuOpen)
                {
                    <div class="dropdown-menu show position-absolute end-0 mt-1 shadow py-1" style="z-index:40;min-width:10rem">
                        <button type="button" class="dropdown-item" @onclick='@(() => ExportAndCloseAsync("csv"))'>CSV</button>
                        <button type="button" class="dropdown-item" @onclick='@(() => ExportAndCloseAsync("xlsx"))'>Excel</button>
                        <button type="button" class="dropdown-item" @onclick='@(() => ExportAndCloseAsync("pdf"))'>PDF</button>
                    </div>
                }
            </div>
            <label class="btn btn-outline-secondary btn-sm mb-0" title="导入 .xlsx，工作表名 Products">
                <i class="bi bi-upload me-1"></i>导入
                <InputFile OnChange="ImportExcelAsync" accept=".xlsx" class="d-none" />
            </label>
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ReloadAllAsync" disabled="@_busy">
                <i class="bi bi-arrow-clockwise me-1"></i>刷新
            </button>
        </ToolbarEnd>
    </EvolverDataTable>
}
else if ((_pane == ProductPane.Create || _pane == ProductPane.Edit))
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">返回商品列表</button>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">@(_pane == ProductPane.Create ? "新建商品" : $"编辑商品 - #{_id}")</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">商品编号</label>
                    <input class="form-control" value="@(_pane == ProductPane.Create ? "-" : _id.ToString())" disabled />
                </div>
                <div class="col-md-3">
                    <label class="form-label">商品代码 <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="_code" @bind:event="oninput" disabled="@_busy" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">商品名称 <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="_name" @bind:event="oninput" disabled="@_busy" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">商品类型</label>
                    <select class="form-select" @bind="_productTypeCode" disabled="@_busy">
                        <option value="">-- 请选择 --</option>
                        @foreach (var c in _productTypeOptions)
                        {
                            <option value="@c.Code">@c.Name (@c.Code)</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">单位编号</label>
                    <input class="form-control" @bind="_unitCode" @bind:event="oninput" disabled="@_busy" list="unit-options" />
                    <datalist id="unit-options">
                        @foreach (var u in _unitOptions)
                        {
                            <option value="@u"></option>
                        }
                    </datalist>
                </div>
                <div class="col-md-3">
                    <label class="form-label">商品条码</label>
                    <input class="form-control" @bind="_barcode" @bind:event="oninput" disabled="@_busy" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">品牌</label>
                    <input class="form-control" @bind="_brand" @bind:event="oninput" disabled="@_busy" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">型号</label>
                    <input class="form-control" @bind="_model" @bind:event="oninput" disabled="@_busy" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">成本单价</label>
                    <input class="form-control" inputmode="decimal" @bind="_unitCostStr" disabled="@_busy" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">建议售价</label>
                    <input class="form-control" inputmode="decimal" @bind="_suggestedPriceStr" disabled="@_busy" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">理论库存</label>
                    <input class="form-control" inputmode="decimal" @bind="_theoreticalStockStr" disabled="@_busy" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">实际库存</label>
                    <input class="form-control" inputmode="decimal" @bind="_actualStockStr" disabled="@_busy" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">警戒库存</label>
                    <input class="form-control" inputmode="decimal" @bind="_alertStockStr" disabled="@_busy" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">备注</label>
                    <input class="form-control" @bind="_remark" @bind:event="oninput" disabled="@_busy" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">是否激活</label>
                    <select class="form-select" @bind="_isActive" disabled="@_busy">
                        <option value="true">是</option>
                        <option value="false">否</option>
                    </select>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="button" class="btn btn-primary" @onclick="SaveAsync" disabled="@(_busy || !IsFormValid())">保存</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">取消</button>
            </div>
        </div>
    </div>
}
else if (_pane == ProductPane.DeleteConfirm && _deleteId is not null)
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">返回商品列表</button>
    </div>

    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">确认删除</div>
        <div class="card-body">
            <p class="mb-3">确定删除商品 <strong>@_deleteLabel</strong>（编号 <strong>@_deleteId</strong>）？若有外键关联将自动停用。</p>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-danger" @onclick="DeleteConfirmedAsync" disabled="@_busy">删除</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelToListAsync" disabled="@_busy">取消</button>
            </div>
        </div>
    </div>
}

@code {
    private enum ProductPane { List, Create, Edit, DeleteConfirm }
    private const string ProductTableHostId = "evolver-product-tabulator-host";
    private static readonly JsonSerializerOptions JsonOpts = new() { PropertyNameCaseInsensitive = true };
    private static readonly JsonSerializerOptions TabulatorJsonOpts = new() { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };

    private string? _error;
    private string? _success;
    private bool _busy;
    private ProductPane _pane = ProductPane.List;
    private List<ProductListItemDto>? _rows;
    private sealed record ProductTypeOption(string Code, string Name);
    private List<ProductTypeOption> _productTypeOptions = new();
    private List<string> _unitOptions = new();

    private string _globalFilter = "";
    private bool _exportMenuOpen;
    private bool _exportClickOutsideRegistered;
    private ElementReference _exportDropdownRoot;
    private DotNetObjectReference<Products>? _dotNetRef;
    private int _dataTick;
    private int _tabulatorSyncedTick = -1;

    private long _id;
    private string _code = "";
    private string _name = "";
    private string? _productTypeCode;
    private string? _unitCode;
    private string? _barcode;
    private string? _brand;
    private string? _model;
    private string? _unitCostStr;
    private string? _suggestedPriceStr;
    private string _theoreticalStockStr = "0";
    private string _actualStockStr = "0";
    private string _alertStockStr = "0";
    private string? _remark;
    private bool _isActive = true;

    private long? _deleteId;
    private string _deleteLabel = "";

    protected override async Task OnInitializedAsync()
    {
        await ReloadAllAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pane != ProductPane.List)
        {
            if (_tabulatorSyncedTick >= 0)
            {
                await DestroyTabulatorAsync();
                _tabulatorSyncedTick = -1;
            }
            return;
        }

        if (_exportMenuOpen && !_exportClickOutsideRegistered)
        {
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("evolverUi.startExportMenuClickOutside", _exportDropdownRoot, _dotNetRef, nameof(OnExportMenuClickOutside));
                _exportClickOutsideRegistered = true;
            }
            catch (JSDisconnectedException) { }
        }
        else if (!_exportMenuOpen && _exportClickOutsideRegistered)
        {
            try { await JS.InvokeVoidAsync("evolverUi.stopExportMenuClickOutside"); } catch (JSDisconnectedException) { }
            _exportClickOutsideRegistered = false;
        }

        if (_rows is null || _dataTick == _tabulatorSyncedTick)
            return;

        await SyncProductsToDomAsync();
    }

    private async Task ReloadAllAsync()
    {
        _error = null;
        _success = null;
        _globalFilter = "";
        _exportMenuOpen = false;
        await Task.WhenAll(LoadProductsAsync(), LoadReferenceOptionsAsync());
    }

    private async Task LoadReferenceOptionsAsync()
    {
        try
        {
            var categories = await Http.GetFromJsonAsync<ApiEnvelopeJson<List<EnumValueDto>>>("api/enum-config/values?enumTypeCode=ProductType");
            _productTypeOptions = categories?.Success == true && categories.Data is not null
                ? categories.Data
                    .Where(x => x.IsActive)
                    .Select(x => new ProductTypeOption(x.EnumValueCode, x.Name))
                    .DistinctBy(x => x.Code, StringComparer.OrdinalIgnoreCase)
                    .OrderBy(x => x.Code)
                    .ToList()
                : new();
        }
        catch
        {
            _productTypeOptions = new();
        }

        try
        {
            var units = await Http.GetFromJsonAsync<ApiEnvelopeJson<List<UnitListItemDto>>>("api/units");
            _unitOptions = units?.Success == true && units.Data is not null
                ? units.Data.Select(x => x.Code).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList()
                : new();
        }
        catch
        {
            _unitOptions = new();
        }
    }

    private async Task LoadProductsAsync()
    {
        try
        {
            var env = await Http.GetFromJsonAsync<ApiEnvelopeJson<List<ProductListItemDto>>>("api/products");
            _rows = env?.Success == true ? env.Data ?? new() : new();
            if (env?.Success == false)
                _error = env.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _rows = new();
        }
        finally
        {
            _dataTick++;
        }
    }

    private async Task SyncProductsToDomAsync()
    {
        if (_rows is null)
            return;
        try
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            var json = JsonSerializer.Serialize(_rows.Select(x => new
            {
                id = x.Id,
                code = x.Code,
                name = x.Name,
                productTypeCode = x.ProductTypeCode ?? "-",
                unitCode = x.UnitCode ?? "-",
                barcode = x.Barcode ?? "-",
                brand = x.Brand ?? "-",
                model = x.Model ?? "-",
                unitCostText = x.UnitCost?.ToString("0.##", CultureInfo.InvariantCulture) ?? "-",
                suggestedPriceText = x.SuggestedPrice?.ToString("0.##", CultureInfo.InvariantCulture) ?? "-",
                theoreticalStockText = x.TheoreticalStock.ToString("0.##", CultureInfo.InvariantCulture),
                actualStockText = x.ActualStock.ToString("0.##", CultureInfo.InvariantCulture),
                alertStockText = x.AlertStock.ToString("0.##", CultureInfo.InvariantCulture),
                remark = x.Remark ?? "-",
                isActive = x.IsActive,
                statusText = x.IsActive ? "是" : "否",
                updateTimeText = x.UpdateTime?.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture) ?? "-",
                updateByUserName = x.UpdateByUserName ?? "-"
            }).ToList(), TabulatorJsonOpts);
            await EvolverDataTableInterop.SyncAsync(JS, ProductTableHostId, json, _dotNetRef, EvolverDataTableSchemas.Products, null);
            _tabulatorSyncedTick = _dataTick;
            await ApplyGlobalFilterJsAsync();
        }
        catch (JSDisconnectedException) { }
    }

    private async Task DestroyTabulatorAsync()
    {
        try { await EvolverDataTableInterop.DestroyAsync(JS, ProductTableHostId); }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { }
    }

    private async Task OnGlobalFilterInput(ChangeEventArgs e)
    {
        _globalFilter = e.Value?.ToString() ?? "";
        await ApplyGlobalFilterJsAsync();
    }

    private async Task ApplyGlobalFilterJsAsync()
    {
        try { await EvolverDataTableInterop.SetGlobalFilterAsync(JS, ProductTableHostId, _globalFilter); }
        catch (JSDisconnectedException) { }
    }

    private void OpenCreate()
    {
        _pane = ProductPane.Create;
        _id = 0;
        _code = "";
        _name = "";
        _productTypeCode = null;
        _unitCode = null;
        _barcode = null;
        _brand = null;
        _model = null;
        _unitCostStr = null;
        _suggestedPriceStr = null;
        _theoreticalStockStr = "0";
        _actualStockStr = "0";
        _alertStockStr = "0";
        _remark = null;
        _isActive = true;
        _error = null;
        _success = null;
    }

    private async Task OpenEditAsync(long id)
    {
        _pane = ProductPane.Edit;
        _error = null;
        _success = null;
        try
        {
            var env = await Http.GetFromJsonAsync<ApiEnvelopeJson<ProductListItemDto>>($"api/products/{id}");
            if (env?.Success != true || env.Data is null)
            {
                _error = env?.Message ?? "加载商品详情失败。";
                await CancelToListAsync();
                return;
            }

            var p = env.Data;
            _id = p.Id;
            _code = p.Code;
            _name = p.Name;
            _productTypeCode = p.ProductTypeCode;
            _unitCode = p.UnitCode;
            _barcode = p.Barcode;
            _brand = p.Brand;
            _model = p.Model;
            _unitCostStr = p.UnitCost?.ToString(CultureInfo.InvariantCulture);
            _suggestedPriceStr = p.SuggestedPrice?.ToString(CultureInfo.InvariantCulture);
            _theoreticalStockStr = p.TheoreticalStock.ToString(CultureInfo.InvariantCulture);
            _actualStockStr = p.ActualStock.ToString(CultureInfo.InvariantCulture);
            _alertStockStr = p.AlertStock.ToString(CultureInfo.InvariantCulture);
            _remark = p.Remark;
            _isActive = p.IsActive;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            await CancelToListAsync();
        }
    }

    private bool IsFormValid() => !string.IsNullOrWhiteSpace(_code) && !string.IsNullOrWhiteSpace(_name);

    private UpsertProductDto BuildPayload()
    {
        decimal.TryParse(_unitCostStr, NumberStyles.Any, CultureInfo.InvariantCulture, out var unitCostValue);
        var hasUnitCost = decimal.TryParse(_unitCostStr, NumberStyles.Any, CultureInfo.InvariantCulture, out _);
        decimal.TryParse(_suggestedPriceStr, NumberStyles.Any, CultureInfo.InvariantCulture, out var suggestedPriceValue);
        var hasSuggestedPrice = decimal.TryParse(_suggestedPriceStr, NumberStyles.Any, CultureInfo.InvariantCulture, out _);
        decimal.TryParse(_theoreticalStockStr, NumberStyles.Any, CultureInfo.InvariantCulture, out var theoreticalStock);
        decimal.TryParse(_actualStockStr, NumberStyles.Any, CultureInfo.InvariantCulture, out var actualStock);
        decimal.TryParse(_alertStockStr, NumberStyles.Any, CultureInfo.InvariantCulture, out var alertStock);

        return new UpsertProductDto(
            _code.Trim(),
            _name.Trim(),
            string.IsNullOrWhiteSpace(_productTypeCode) ? null : _productTypeCode.Trim(),
            string.IsNullOrWhiteSpace(_unitCode) ? null : _unitCode.Trim(),
            string.IsNullOrWhiteSpace(_barcode) ? null : _barcode.Trim(),
            string.IsNullOrWhiteSpace(_brand) ? null : _brand.Trim(),
            string.IsNullOrWhiteSpace(_model) ? null : _model.Trim(),
            hasUnitCost ? unitCostValue : null,
            hasSuggestedPrice ? suggestedPriceValue : null,
            theoreticalStock,
            actualStock,
            alertStock,
            string.IsNullOrWhiteSpace(_remark) ? null : _remark.Trim(),
            _isActive);
    }

    private async Task SaveAsync()
    {
        if (_busy || !IsFormValid())
            return;

        _busy = true;
        _error = null;
        _success = null;
        try
        {
            var payload = BuildPayload();
            HttpResponseMessage resp;
            if (_pane == ProductPane.Create)
                resp = await Http.PostAsJsonAsync("api/products", payload);
            else
                resp = await Http.PutAsJsonAsync($"api/products/{_id}", payload);

            if (!resp.IsSuccessStatusCode)
            {
                _error = await ReadErrorAsync(resp);
                return;
            }

            _success = _pane == ProductPane.Create ? "商品已创建。" : "商品已保存。";
            await CancelToListAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    [JSInvokable]
    public async Task OnProductTableEdit(long id)
    {
        await OpenEditAsync(id);
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnProductTableDelete(long id)
    {
        _deleteId = id;
        _deleteLabel = _rows?.FirstOrDefault(x => x.Id == id)?.Name ?? $"#{id}";
        _pane = ProductPane.DeleteConfirm;
        return InvokeAsync(StateHasChanged);
    }

    private async Task DeleteConfirmedAsync()
    {
        if (_busy || _deleteId is not { } id)
            return;

        _busy = true;
        _error = null;
        _success = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/products/{id}");
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ReadErrorAsync(resp);
                return;
            }

            if (resp.StatusCode == System.Net.HttpStatusCode.OK)
            {
                var txt = await resp.Content.ReadAsStringAsync();
                _success = string.IsNullOrWhiteSpace(txt) ? "存在关联数据，已自动停用。" : txt.Trim('"');
            }
            else
            {
                _success = "商品已删除。";
            }

            await CancelToListAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ImportExcelAsync(InputFileChangeEventArgs e)
    {
        if (_busy || e.FileCount == 0)
            return;
        _busy = true;
        _error = null;
        _success = null;
        try
        {
            await using var stream = e.File.OpenReadStream(20_000_000);
            using var content = new MultipartFormDataContent();
            content.Add(new StreamContent(stream), "file", e.File.Name);
            var resp = await Http.PostAsync("api/products/import", content);
            var text = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
            {
                _error = ReadErrorText(text);
                return;
            }

            var env = JsonSerializer.Deserialize<ApiEnvelopeJson<ProductImportResultDto>>(text, JsonOpts);
            if (env?.Success == true && env.Data is { } d)
                _success = $"导入完成：新建 {d.Created}，更新 {d.Updated}，跳过 {d.Skipped}。";
            else
                _error = env?.Message ?? "导入失败。";

            await ReloadAllAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ExportAndCloseAsync(string format)
    {
        _exportMenuOpen = false;
        if (_busy) return;
        _busy = true;
        try { await EvolverDataTableInterop.DownloadAsync(JS, ProductTableHostId, format); }
        finally { _busy = false; }
    }

    [JSInvokable]
    public Task OnExportMenuClickOutside()
    {
        _exportMenuOpen = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task CancelToListAsync()
    {
        _pane = ProductPane.List;
        _deleteId = null;
        _deleteLabel = "";
        await ReloadAllAsync();
        await InvokeAsync(StateHasChanged);
    }

    private static string ReadErrorText(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "请求失败。";
        try
        {
            var env = JsonSerializer.Deserialize<ApiEnvelopeJson<JsonElement>>(text, JsonOpts);
            if (!string.IsNullOrEmpty(env?.Message))
                return env.Message!;
        }
        catch { }

        return text.Length > 400 ? text[..400] + "…" : text;
    }

    private async Task<string> ReadErrorAsync(HttpResponseMessage resp)
    {
        var text = await resp.Content.ReadAsStringAsync();
        return ReadErrorText(text);
    }

    public async ValueTask DisposeAsync()
    {
        if (_exportClickOutsideRegistered)
        {
            try { await JS.InvokeVoidAsync("evolverUi.stopExportMenuClickOutside"); } catch (JSDisconnectedException) { }
        }
        await DestroyTabulatorAsync();
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }
}

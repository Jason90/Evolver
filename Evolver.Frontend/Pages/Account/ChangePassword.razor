@page "/account/password"
@using Evolver.Shared.Api
@using Evolver.Shared.Dtos

<PageTitle>更改密码</PageTitle>

<h1>更改密码</h1>
<p class="text-muted">使用 Identity <code>ChangePasswordAsync</code> 校验当前密码。</p>

<div class="row">
    <div class="col-12 col-md-6">
        @if (!string.IsNullOrEmpty(_success))
        {
            <div class="alert alert-success">@_success</div>
        }
        @if (_error is not null)
        {
            <div class="alert alert-danger">@_error</div>
        }
        <div class="mb-3">
            <label class="form-label">当前密码</label>
            <input type="password" class="form-control" @bind="_current" autocomplete="current-password" />
        </div>
        <div class="mb-3">
            <label class="form-label">新密码</label>
            <input type="password" class="form-control" @bind="_next" autocomplete="new-password" />
        </div>
        <div class="mb-3">
            <label class="form-label">确认新密码</label>
            <input type="password" class="form-control" @bind="_confirm" autocomplete="new-password" />
        </div>
        <button type="button" class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">保存</button>
        <a class="btn btn-outline-secondary ms-2" href="/account">返回我的帐户</a>
    </div>
</div>

@code {
    [Inject] private HttpClient Http { get; set; } = default!;

    private string _current = "";
    private string _next = "";
    private string _confirm = "";
    private bool _busy;
    private string? _error;
    private string? _success;

    private async Task SaveAsync()
    {
        _busy = true;
        _error = null;
        _success = null;
        try
        {
            if (_next != _confirm)
            {
                _error = "两次输入的新密码不一致。";
                return;
            }

            var resp = await Http.PostAsJsonAsync("api/account/change-password", new ChangeOwnPasswordDto(_current, _next));
            var text = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
            {
                var env = System.Text.Json.JsonSerializer.Deserialize<ApiEnvelopeJson<object>>(text,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                _error = env?.Message ?? text;
                return;
            }

            _success = "密码已更新，请牢记新密码。";
            _current = "";
            _next = "";
            _confirm = "";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}

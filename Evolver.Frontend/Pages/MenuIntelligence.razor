@page "/menu-intelligence"
@using Evolver.Shared.Api
@using Evolver.Shared.Dtos
@inject HttpClient Http

<PageTitle>Menu Intelligence</PageTitle>

<h1>Menu Intelligence</h1>

<div class="mb-3">
    <label class="form-label">Market</label>
    <input class="form-control" @bind="_market" @bind:event="oninput" placeholder="例如：Britomart Market" />
    <button class="btn btn-primary mt-2" @onclick="Load">Load</button>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_rows is null)
{
    <p>点击 Load 加载最新结果。</p>
}
else if (_rows.Count == 0)
{
    <p>暂无数据（请先 Import）。</p>
}
else
{
    <p>AsOf: @_rows[0].AsOfDate, Market: @_rows[0].Market</p>

    <table class="table table-striped table-sm">
        <thead>
        <tr>
            <th>Rank</th>
            <th>Product</th>
            <th class="text-end">Planned</th>
            <th class="text-end">Price</th>
            <th class="text-end">Unit Cost</th>
            <th class="text-end">Gross Profit</th>
            <th class="text-end">Total Profit</th>
            <th>Action</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var r in _rows)
        {
            <tr>
                <td>@r.Rank</td>
                <td>@r.ProductName (@r.ProductCode)</td>
                <td class="text-end">@r.PlannedOrders</td>
                <td class="text-end">@r.Price</td>
                <td class="text-end">@r.UnitCost</td>
                <td class="text-end">@r.GrossProfit</td>
                <td class="text-end">@r.TotalProfit</td>
                <td>@r.MenuAction</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private string? _market;
    private List<MenuIntelligenceDto>? _rows;
    private string? _error;

    private async Task Load()
    {
        _error = null;
        _rows = null;

        try
        {
            var url = string.IsNullOrWhiteSpace(_market)
                ? "api/menu-intelligence"
                : $"api/menu-intelligence?market={Uri.EscapeDataString(_market)}";

            var envelope = await Http.GetFromJsonAsync<ApiEnvelopeJson<List<MenuIntelligenceDto>>>(url);
            if (envelope?.Success == true)
                _rows = envelope.Data ?? new();
            else
            {
                _rows = new();
                _error = envelope?.Message ?? "Request failed.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}


@page "/login"
@attribute [AllowAnonymous]
@using Evolver.Shared.Api
@using Evolver.Shared.Dtos
@using Evolver.Frontend.Services
@inject HttpClient Http
@inject AuthTokenStore Tokens
@inject NavigationManager Nav
@inject IJSRuntime Js

<PageTitle>登录</PageTitle>

<h1>登录</h1>

<div class="row">
    <div class="col-12 col-md-6">
        <div class="mb-3">
            <label class="form-label">用户名</label>
            <input class="form-control" @bind="_userName" />
        </div>
        <div class="mb-3">
            <label class="form-label">密码</label>
            <input class="form-control" type="password" @bind="_password" />
        </div>
        <div class="mb-3">
            <label class="form-label">租户编号（可选）</label>
            <input class="form-control" inputmode="numeric" @bind="_tenantIdInput" placeholder="留空：仅当该用户名全局唯一时可用" />
        </div>
        <button class="btn btn-primary" @onclick="DoLogin" disabled="@_busy">登录</button>
        <button class="btn btn-outline-secondary ms-2" @onclick="DoLogout" disabled="@_busy">退出登录</button>
        <div class="mt-3 small">
            <a href="/forgot-password">忘记密码？</a>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert @_errorAlertClass mt-3">@_error</div>
}

@if (!string.IsNullOrWhiteSpace(Tokens.AccessToken))
{
    <div class="alert alert-success mt-3">已登录，令牌已写入浏览器会话。</div>
}

@code {
    private string _userName = "admin";
    private string _password = "admin123";
    private string _tenantIdInput = "";
    private bool _busy;
    private string? _error;
    private string _errorAlertClass = "alert-danger";

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(Tokens.AccessToken))
            Nav.NavigateTo("/", replace: true);
    }

    private async Task DoLogin()
    {
        _busy = true;
        _error = null;
        _errorAlertClass = "alert-danger";
        try
        {
            int? tenantId = null;
            if (!string.IsNullOrWhiteSpace(_tenantIdInput) &&
                int.TryParse(_tenantIdInput.Trim(), out var tid) &&
                tid > 0)
            {
                tenantId = tid;
            }

            var resp = await Http.PostAsJsonAsync(
                "api/auth/login",
                new LoginRequestDto(_userName, _password, tenantId));
            if (!resp.IsSuccessStatusCode)
            {
                var err = await TryReadEnvelopeAsync(resp);
                if (!string.IsNullOrWhiteSpace(err.Message))
                {
                    _error = err.Message;
                    _errorAlertClass = err.StatusCode == 403 ? "alert-warning" : "alert-danger";
                }
                else
                {
                    _error = $"登录失败: {(int)resp.StatusCode} {resp.ReasonPhrase}";
                }

                return;
            }

            var envelope = await resp.Content.ReadFromJsonAsync<ApiEnvelopeJson<LoginResponseDto>>();
            var login = envelope?.Data;
            if (envelope?.Success != true || login is null || string.IsNullOrWhiteSpace(login.AccessToken))
            {
                _error = envelope?.Message ?? "登录响应无效。";
                return;
            }

            Tokens.Set(login.AccessToken);
            await Tokens.PersistToBrowserAsync(Js);
            Nav.NavigateTo("/", replace: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DoLogout()
    {
        Tokens.Clear();
        await Tokens.ClearBrowserAsync(Js);
    }

    private static async Task<(string? Message, int StatusCode)> TryReadEnvelopeAsync(HttpResponseMessage resp)
    {
        var code = (int)resp.StatusCode;
        try
        {
            var env = await resp.Content.ReadFromJsonAsync<ApiEnvelopeJson<object>>();
            if (env is not null && !string.IsNullOrWhiteSpace(env.Message))
                return (env.Message, code);
        }
        catch
        {
            /* ignore */
        }

        return (null, code);
    }
}

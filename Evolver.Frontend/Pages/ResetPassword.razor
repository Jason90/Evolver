@page "/reset-password"
@attribute [AllowAnonymous]
@using Evolver.Shared.Api
@using Evolver.Shared.Dtos
@inject NavigationManager Nav

<PageTitle>重置密码</PageTitle>

<h1>重置密码</h1>
<p class="text-muted">使用 Identity <code>ResetPasswordAsync</code>。令牌来自忘记密码接口或管理员。</p>

<div class="row">
    <div class="col-12 col-md-6">
        @if (!string.IsNullOrEmpty(_success))
        {
            <div class="alert alert-success">@_success <a href="login">去登录</a></div>
        }
        @if (_error is not null)
        {
            <div class="alert alert-danger">@_error</div>
        }
        <div class="mb-3">
            <label class="form-label">用户名</label>
            <input class="form-control" @bind="_userName" autocomplete="username" />
        </div>
        <div class="mb-3">
            <label class="form-label">重置令牌</label>
            <textarea class="form-control font-monospace small" rows="3" @bind="_token"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">新密码</label>
            <input type="password" class="form-control" @bind="_password" autocomplete="new-password" />
        </div>
        <button type="button" class="btn btn-primary" @onclick="SubmitAsync" disabled="@_busy">重置并保存</button>
        <a class="btn btn-outline-secondary ms-2" href="login">返回登录</a>
    </div>
</div>

@code {
    [Inject] private HttpClient Http { get; set; } = default!;

    private string _userName = "";
    private string _token = "";
    private string _password = "";
    private bool _busy;
    private string? _error;
    private string? _success;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = uri.Query;
        if (string.IsNullOrEmpty(query) || query == "?")
            return;
        if (query.StartsWith('?'))
            query = query[1..];
        foreach (var segment in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var eq = segment.IndexOf('=');
            if (eq <= 0) continue;
            var key = Uri.UnescapeDataString(segment[..eq]);
            if (!string.Equals(key, "userName", StringComparison.OrdinalIgnoreCase))
                continue;
            var value = segment[(eq + 1)..];
            if (!string.IsNullOrWhiteSpace(value))
                _userName = Uri.UnescapeDataString(value);
            break;
        }
    }

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        _success = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/auth/reset-password",
                new ResetPasswordRequestDto(_userName.Trim(), _token.Trim(), _password));
            var text = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
            {
                var env = System.Text.Json.JsonSerializer.Deserialize<ApiEnvelopeJson<object>>(text,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                _error = env?.Message ?? text;
                return;
            }

            _success = "密码已重置。";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
